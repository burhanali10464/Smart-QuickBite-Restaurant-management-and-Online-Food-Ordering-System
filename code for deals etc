IF OBJECT_ID('deals', 'U') IS NULL
CREATE TABLE deals (
    deal_id INT IDENTITY(1,1) PRIMARY KEY,
    deal_name VARCHAR(100) NOT NULL,
    deal_description VARCHAR(255),
    deal_price INT NOT NULL,
    image_url VARCHAR(500),
    availability_status VARCHAR(30) DEFAULT 'Available'
);
GO

IF OBJECT_ID('discounts', 'U') IS NULL
CREATE TABLE discounts (
    discount_id INT IDENTITY(1,1) PRIMARY KEY,
    discount_name VARCHAR(100) NOT NULL,
    discount_type VARCHAR(50) NOT NULL,
    discount_percent INT NOT NULL,
    payment_method VARCHAR(50),
    is_active VARCHAR(20) DEFAULT 'Active'
);
GO

IF COL_LENGTH('orders', 'discount_name') IS NULL
ALTER TABLE orders ADD discount_name VARCHAR(100) NULL;
GO

IF COL_LENGTH('orders', 'discount_amount') IS NULL
ALTER TABLE orders ADD discount_amount INT DEFAULT 0;
GO

IF COL_LENGTH('orders', 'final_amount') IS NULL
ALTER TABLE orders ADD final_amount INT DEFAULT 0;
GO


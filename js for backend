app.post("/place-order", async (req, res) => {
    const transaction = new sql.Transaction(pool);

    try {
        const { name, phone, email, items, deals, paymentMethod, discountName, discountPercent } = req.body;

        const foodItems = Array.isArray(items) ? items : [];
        const dealItems = Array.isArray(deals) ? deals : [];

        if (!name || !phone || (foodItems.length === 0 && dealItems.length === 0) || !paymentMethod) {
            return res.status(400).json({ message: "All fields required" });
        }

        await transaction.begin();

        let request = new sql.Request(transaction);

        let customerResult = await request
            .input("name", sql.VarChar(100), name)
            .query(`
                SELECT customer_id
                FROM customers
                WHERE customer_name = @name
            `);

        let customerId;

        if (customerResult.recordset.length > 0) {
            customerId = customerResult.recordset[0].customer_id;
        } else {
            request = new sql.Request(transaction);

            let newCustomer = await request
                .input("name", sql.VarChar(100), name)
                .query(`
                    INSERT INTO customers (customer_name)
                    VALUES (@name);

                    SELECT SCOPE_IDENTITY() AS customer_id;
                `);

            customerId = newCustomer.recordset[0].customer_id;

            request = new sql.Request(transaction);

            await request
                .input("customer_id", sql.Int, customerId)
                .input("phone", sql.VarChar(20), phone)
                .input("email", sql.VarChar(100), email || name.toLowerCase().replaceAll(" ", "") + "@gmail.com")
                .query(`
                    INSERT INTO customer_contacts (customer_id, phone, email)
                    VALUES (@customer_id, @phone, @email)
                `);
        }

        request = new sql.Request(transaction);

        let orderResult = await request
            .input("customer_id", sql.Int, customerId)
            .query(`
                INSERT INTO orders (customer_id, status_id)
                VALUES (@customer_id, 1);

                SELECT SCOPE_IDENTITY() AS order_id;
            `);

        const orderId = orderResult.recordset[0].order_id;
        let subTotal = 0;

        for (const item of foodItems) {
            request = new sql.Request(transaction);

            const foodResult = await request
                .input("food_id", sql.Int, item.food_id)
                .query(`
                    SELECT food_id, price
                    FROM food_items
                    WHERE food_id = @food_id
                    AND availability_status = 'Available'
                `);

            if (foodResult.recordset.length === 0) {
                await transaction.rollback();
                return res.status(404).json({ message: "Food item not available" });
            }

            const foodId = foodResult.recordset[0].food_id;
            const price = foodResult.recordset[0].price;
            const qty = parseInt(item.quantity);
            const total = price * qty;

            subTotal += total;

            request = new sql.Request(transaction);

            await request
                .input("order_id", sql.Int, orderId)
                .input("food_id", sql.Int, foodId)
                .input("quantity", sql.Int, qty)
                .input("total_price", sql.Int, total)
                .query(`
                    INSERT INTO order_details (order_id, food_id, quantity, total_price)
                    VALUES (@order_id, @food_id, @quantity, @total_price)
                `);
        }

        for (const deal of dealItems) {
            request = new sql.Request(transaction);

            const dealResult = await request
                .input("deal_id", sql.Int, deal.deal_id)
                .query(`
                    SELECT deal_id, deal_price
                    FROM deals
                    WHERE deal_id = @deal_id
                    AND availability_status = 'Available'
                `);

            if (dealResult.recordset.length === 0) {
                await transaction.rollback();
                return res.status(404).json({ message: "Deal not available" });
            }

            const dealId = dealResult.recordset[0].deal_id;
            const price = dealResult.recordset[0].deal_price;
            const qty = parseInt(deal.quantity);
            const total = price * qty;

            subTotal += total;

            request = new sql.Request(transaction);

            await request
                .input("order_id", sql.Int, orderId)
                .input("deal_id", sql.Int, dealId)
                .input("quantity", sql.Int, qty)
                .input("total_price", sql.Int, total)
                .query(`
                    INSERT INTO order_deals (order_id, deal_id, quantity, total_price)
                    VALUES (@order_id, @deal_id, @quantity, @total_price)
                `);
        }

        const percent = parseInt(discountPercent) || 0;
        const discountAmount = Math.round((subTotal * percent) / 100);
        const finalAmount = subTotal - discountAmount;

        request = new sql.Request(transaction);

        await request
            .input("order_id", sql.Int, orderId)
            .input("discount_name", sql.VarChar(100), discountName || "No Discount")
            .input("discount_amount", sql.Int, discountAmount)
            .input("final_amount", sql.Int, finalAmount)
            .query(`
                UPDATE orders
                SET discount_name = @discount_name,
                    discount_amount = @discount_amount,
                    final_amount = @final_amount
                WHERE order_id = @order_id
            `);

        request = new sql.Request(transaction);

        await request
            .input("order_id", sql.Int, orderId)
            .input("payment_method", sql.VarChar(50), paymentMethod)
            .query(`
                INSERT INTO payments (order_id, payment_method, payment_status)
                VALUES (@order_id, @payment_method, 'Paid')
            `);

        await transaction.commit();

        res.json({
            message: "Order placed successfully",
            orderId,
            subTotal,
            discountAmount,
            total: finalAmount
        });

    } catch (err) {
        try {
            await transaction.rollback();
        } catch (rollbackErr) {}

        console.error("❌ Order Error:");
        console.error(err);
        res.status(500).json({ message: "Error placing order" });
    }
});


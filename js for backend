                OR payments.payment_method LIKE @keyword
                OR order_status.status_name LIKE @keyword

                ORDER BY order_id DESC
            `);

        res.json(result.recordset);
    } catch (err) {
        res.status(500).json({ message: "Error searching orders" });
    }
});


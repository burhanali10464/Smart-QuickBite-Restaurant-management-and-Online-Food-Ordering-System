            JOIN customer_contacts ON customer_contacts.customer_id = customers.customer_id
            JOIN order_deals ON order_deals.order_id = orders.order_id
            JOIN deals ON deals.deal_id = order_deals.deal_id
            JOIN payments ON payments.order_id = orders.order_id
            JOIN order_status ON order_status.status_id = orders.status_id


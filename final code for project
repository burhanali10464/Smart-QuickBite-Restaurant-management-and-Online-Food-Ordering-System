CREATE PROCEDURE GetDashboardStats
AS
BEGIN
    SELECT
        (SELECT COUNT(*) FROM customers) AS TotalCustomers,
        (SELECT COUNT(*) FROM orders) AS TotalOrders,
        (SELECT ISNULL(SUM(final_amount),0) FROM orders) AS TotalRevenue,
        (SELECT COUNT(*) FROM orders WHERE status_id = 1) AS PendingOrders;
END;
GO

CREATE PROCEDURE GetTopSellingFood
AS
BEGIN
    SELECT TOP 5
        food_items.food_name,
        SUM(order_details.quantity) AS TotalQuantity,
        SUM(order_details.total_price) AS TotalRevenue
    FROM order_details
    JOIN food_items ON food_items.food_id = order_details.food_id
    GROUP BY food_items.food_name
    ORDER BY TotalQuantity DESC;
END;
GO

CREATE PROCEDURE GetPaymentSummary
AS
BEGIN
    SELECT payment_method, COUNT(*) AS TotalPayments
    FROM payments
    GROUP BY payment_method;
END;
GO

CREATE PROCEDURE GetDeals
AS
BEGIN
    SELECT *
    FROM deals
    WHERE availability_status = 'Available'
    ORDER BY deal_id DESC;
END;
GO

CREATE PROCEDURE GetDiscounts
AS
BEGIN
    SELECT *
    FROM discounts
    WHERE is_active = 'Active';
END;
GO


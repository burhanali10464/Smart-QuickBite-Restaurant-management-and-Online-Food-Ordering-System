USE food_order_db;
GO

CREATE TABLE customers (
    customer_id INT IDENTITY(1,1) PRIMARY KEY,
    customer_name VARCHAR(100) NOT NULL,
    created_at DATETIME DEFAULT GETDATE()
);

CREATE TABLE customer_contacts (
    contact_id INT IDENTITY(1,1) PRIMARY KEY,
    customer_id INT NOT NULL,
    phone VARCHAR(20) NOT NULL,
    email VARCHAR(100),
    FOREIGN KEY (customer_id) REFERENCES customers(customer_id)
);

CREATE TABLE food_categories (
    category_id INT IDENTITY(1,1) PRIMARY KEY,
    category_name VARCHAR(100) NOT NULL UNIQUE
);

CREATE TABLE food_items (
    food_id INT IDENTITY(1,1) PRIMARY KEY,
    category_id INT NOT NULL,
    food_name VARCHAR(100) NOT NULL,
    price INT NOT NULL CHECK (price > 0),
    description VARCHAR(255),
    image_url VARCHAR(500),
    rating DECIMAL(2,1) DEFAULT 4.5,
    availability_status VARCHAR(30) DEFAULT 'Available',
    FOREIGN KEY (category_id) REFERENCES food_categories(category_id)
);

CREATE TABLE order_status (
    status_id INT IDENTITY(1,1) PRIMARY KEY,
    status_name VARCHAR(50) NOT NULL UNIQUE
);

CREATE TABLE orders (
    order_id INT IDENTITY(1,1) PRIMARY KEY,
    customer_id INT NOT NULL,
    status_id INT DEFAULT 1,
    order_date DATETIME DEFAULT GETDATE(),
    discount_name VARCHAR(100) DEFAULT 'No Discount',
    discount_amount INT DEFAULT 0,
    final_amount INT DEFAULT 0,
    FOREIGN KEY (customer_id) REFERENCES customers(customer_id),
    FOREIGN KEY (status_id) REFERENCES order_status(status_id)
);

CREATE TABLE order_details (
    detail_id INT IDENTITY(1,1) PRIMARY KEY,
    order_id INT NOT NULL,
    food_id INT NOT NULL,
    quantity INT NOT NULL CHECK (quantity > 0),
    total_price INT NOT NULL CHECK (total_price >= 0),
    FOREIGN KEY (order_id) REFERENCES orders(order_id),
    FOREIGN KEY (food_id) REFERENCES food_items(food_id)
);

CREATE TABLE payments (
    payment_id INT IDENTITY(1,1) PRIMARY KEY,
    order_id INT NOT NULL,
    payment_method VARCHAR(50) NOT NULL,
    payment_status VARCHAR(50) DEFAULT 'Paid',
    FOREIGN KEY (order_id) REFERENCES orders(order_id)
);

CREATE TABLE deals (
    deal_id INT IDENTITY(1,1) PRIMARY KEY,
    deal_name VARCHAR(100) NOT NULL,
    deal_description VARCHAR(255),
    deal_price INT NOT NULL,
    image_url VARCHAR(500),
    availability_status VARCHAR(30) DEFAULT 'Available'
);

CREATE TABLE discounts (
    discount_id INT IDENTITY(1,1) PRIMARY KEY,
    discount_name VARCHAR(100) NOT NULL,
    discount_type VARCHAR(50) NOT NULL,
    discount_percent INT NOT NULL,
    payment_method VARCHAR(50),
    is_active VARCHAR(20) DEFAULT 'Active'
);

CREATE TABLE order_deals (
    order_deal_id INT IDENTITY(1,1) PRIMARY KEY,
    order_id INT NOT NULL,
    deal_id INT NOT NULL,
    quantity INT NOT NULL CHECK (quantity > 0),
    total_price INT NOT NULL,
    FOREIGN KEY (order_id) REFERENCES orders(order_id),
    FOREIGN KEY (deal_id) REFERENCES deals(deal_id)
);

CREATE TABLE order_log (
    log_id INT IDENTITY(1,1) PRIMARY KEY,
    order_id INT NOT NULL,
    action_name VARCHAR(100),
    log_date DATETIME DEFAULT GETDATE()
);

CREATE TABLE feedback (
    feedback_id INT IDENTITY(1,1) PRIMARY KEY,
    customer_id INT NOT NULL,
    rating INT CHECK (rating BETWEEN 1 AND 5),
    comments VARCHAR(255),
    feedback_date DATETIME DEFAULT GETDATE(),
    FOREIGN KEY (customer_id) REFERENCES customers(customer_id)
);


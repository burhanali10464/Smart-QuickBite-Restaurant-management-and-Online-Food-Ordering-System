async function updateStatus(){
  const orderId=document.getElementById("statusOrderId").value;
  const statusId=document.getElementById("statusId").value;
  if(!orderId){alert("Please enter order id");return}
  try{
    const res=await fetch("/update-status/"+orderId,{method:"PUT",headers:{"Content-Type":"application/json"},body:JSON.stringify({statusId})});
    const data=await res.json();
    alert(data.message);
    loadOrders();loadDashboard();
  }catch(e){alert("Error updating status")}
}

async function submitFeedback(){
  const customerName=document.getElementById("feedbackName").value.trim();
  const rating=document.getElementById("rating").value;
  const comments=document.getElementById("comments").value.trim();
  if(!customerName){alert("Enter customer name");return}
  try{
    const res=await fetch("/feedback",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({customerName,rating,comments})});
    const data=await res.json();
    alert(data.message);
    document.getElementById("feedbackName").value="";
    document.getElementById("comments").value="";
    loadFeedback();
  }catch(e){alert("Error submitting feedback")}
}

async function loadFeedback(){
  try{
    const res=await fetch("/feedback");
    const feedback=await res.json();
    let output="";
    feedback.forEach(f=>{
      output+=`<div class="order-item"><h4>${f.customer_name}</h4><p><strong>Rating:</strong> ${"⭐".repeat(f.rating)}</p><p><strong>Comments:</strong> ${f.comments||"No comments"}</p></div>`;
    });
    document.getElementById("feedbackList").innerHTML=output||"<p>No feedback found.</p>";
  }catch(e){}
}

loadDashboard();
loadMenu();
loadDeals();
loadDiscounts();
loadOrders();
loadTopFoods();
loadPaymentSummary();
loadFeedback();
</script>
